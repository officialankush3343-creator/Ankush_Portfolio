# Web3Forms — free contact-form backend (https://web3forms.com/)
# Get an access key by entering your email on web3forms.com (no signup required).
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key

# EmailJS configuration (alternative — https://www.emailjs.com/)
# Used as fallback if NEXT_PUBLIC_WEB3FORMS_KEY is not set.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key
